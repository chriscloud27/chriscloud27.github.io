# Dependency security audit (interactive handling)
run_dependency_audit() {
	tmpfile="$(mktemp 2>/dev/null || echo "/tmp/audit_output.$$")"
	if npm audit --production --audit-level=moderate --json >"$tmpfile" 2>&1; then
		log "${GREEN}✔ Dependency audit passed${RESET}"
		rm -f "$tmpfile"
		add_pass
		return 0
	else
		log "${YELLOW}⚠ Dependency audit reported issues:${RESET}"
		cat "$tmpfile" >&2
		rm -f "$tmpfile"
		add_warn
		return 0
	fi
}

run_dependency_audit

# Spellcheck docs
run_check_verbose "Spellcheck docs" "npx cspell \"content/**\" \"docs/**\" || true"

# Build as final verification
run_build_verbose() {
	title="$1"
	shift
	cmd="$@"
	log "${YELLOW}→ ${title} (verbose)${RESET}"
	tmpfile="$(mktemp 2>/dev/null || echo "/tmp/build_output.$$")"
	# Stream output live and save to tmpfile
	if sh -c "$cmd" 2>&1 | tee "$tmpfile"; then
		log "${GREEN}✔ ${title} succeeded${RESET}"
		add_pass
		# Print concise build checklist summary (if present in output)
		patterns="Compiled successfully|Linting and checking validity of types|Collecting page data|Generating static pages|Collecting build traces|Exporting|Finalizing page optimization"
		printf "\n"
		while IFS= read -r pat; do
			match=$(grep -E -m1 "$pat" "$tmpfile" || true)
			if [ -n "$match" ]; then
				# normalize spacing and show a concise line
				printf " ${GREEN}✓${RESET} %s\n" "$match"
			fi
		done <<EOF
Compiled successfully
Linting and checking validity of types
Collecting page data
Generating static pages
Collecting build traces
Exporting
Finalizing page optimization
EOF
		rm -f "$tmpfile"
	else
		log "${RED}✖ ${title} failed — commit aborted${RESET}"
		add_fail
		log "${RED}--- ${title} output ---${RESET}"
		cat "$tmpfile" >&2
		rm -f "$tmpfile"
		print_summary_and_exit
	fi
}

run_check_verbose "MDX validation" "node scripts/validate-mdx.mjs"

run_build_verbose "build" "npm run build"

print_final_summary
log "${GREEN}All pre-commit checks passed. Commit continues...${RESET}"
exit 0
