#!/usr/bin/env sh
set -e

# Color helpers (POSIX-safe)
RED=$(printf '\033[31m')
GREEN=$(printf '\033[32m')
YELLOW=$(printf '\033[33m')
RESET=$(printf '\033[0m')

log() {
	printf "%s\n" "$1"
}

# Result counters
PASS=0
WARN=0
FAIL=0

add_pass() { PASS=$((PASS+1)); }
add_warn() { WARN=$((WARN+1)); }
add_fail() { FAIL=$((FAIL+1)); }

print_summary_and_exit() {
	log ""
	log "${YELLOW}Pre-commit summary:${RESET} ${GREEN}${PASS} passed${RESET}, ${YELLOW}${WARN} warnings${RESET}, ${RED}${FAIL} failures${RESET}"
	if [ "$FAIL" -gt 0 ]; then
		exit 1
	fi
}

print_final_summary() {
  # single-line final summary (no exit)
  printf "\n ${GREEN}succeeded %d${RESET}, ${YELLOW}warning %d${RESET}, ${RED}failure %d${RESET}\n" "$PASS" "$WARN" "$FAIL"
}

run_check() {
	title="$1"
	shift
 	cmd="$@"
 	log "${YELLOW}→ ${title}${RESET}"

	# Capture output to a temp file so we can suppress verbose success output
	tmpfile="$(mktemp 2>/dev/null || echo "/tmp/precommit_output.$$")"
	if sh -c "$cmd" >"$tmpfile" 2>&1; then
		log "${GREEN}✔ ${title} succeeded${RESET}"
		rm -f "$tmpfile"
		add_pass
	else
		log "${RED}✖ ${title} failed — commit aborted${RESET}"
		log "${RED}--- ${title} output ---${RESET}"
		cat "$tmpfile" >&2
		rm -f "$tmpfile"
		add_fail
		print_summary_and_exit
	fi
}

# Verbose runner: streams command output to terminal (use for demonstration/diagnostics)
run_check_verbose() {
	title="$1"
shift
	cmd="$@"
	log "${YELLOW}→ ${title}${RESET}"
	if sh -c "$cmd"; then
		log "${GREEN}✔ ${title} succeeded${RESET}"
		add_pass
	else
		log "${RED}✖ ${title} failed — commit aborted${RESET}"
		add_fail
		print_summary_and_exit
	fi
}

# Whitespace/conflict check with interactive auto-fix option
run_whitespace_check() {
	tmpfile="$(mktemp 2>/dev/null || echo "/tmp/whitespace_output.$$")"
	if git diff --cached --check >"$tmpfile" 2>&1; then
		log "${GREEN}✔ Whitespace/conflict check passed${RESET}"
		rm -f "$tmpfile"
		return 0
	else
		log "${YELLOW}✖ Whitespace/conflict check failed — issues detected:${RESET}"
		cat "$tmpfile" >&2

		# Interactive prompt to auto-fix, ignore, or abort
		if [ -t 0 ]; then
				printf "%s" "${YELLOW}Fix whitespace automatically? [a]uto-fix, [i]gnore, [q]uit: ${RESET}"
				read -r ans
				case "$ans" in
					a|A)
						log "${YELLOW}Applying whitespace fixes to staged diff...${RESET}"
						# Apply staged diff with whitespace fixes
						if git diff --cached -U0 --no-color | git apply --cached --whitespace=fix - >"$tmpfile" 2>&1; then
							# Re-run check
							if git diff --cached --check >"$tmpfile" 2>&1; then
								log "${GREEN}✔ Whitespace issues fixed and staged.${RESET}"
								rm -f "$tmpfile"
								add_pass
								return 0
							else
								log "${RED}✖ Whitespace issues remain after auto-fix; aborting.${RESET}"
								cat "$tmpfile" >&2
								rm -f "$tmpfile"
								add_fail
								print_summary_and_exit
							fi
						else
							log "${RED}✖ Failed to apply whitespace fixes:${RESET}"
							cat "$tmpfile" >&2
							rm -f "$tmpfile"
							add_fail
							print_summary_and_exit
						fi
						;;
					i|I)
						log "${YELLOW}Ignoring whitespace issues and continuing.${RESET}"
						rm -f "$tmpfile"
						add_warn
						return 0
						;;
					*)
						log "${RED}Aborting commit due to whitespace issues.${RESET}"
						cat "$tmpfile" >&2
						rm -f "$tmpfile"
						add_fail
						print_summary_and_exit
						;;
				esac
		else
			log "${YELLOW}✖ Whitespace issues detected and no interactive terminal available — aborting.${RESET}"
			cat "$tmpfile" >&2
			rm -f "$tmpfile"
			exit 1
		fi
	fi
}

# Prettier verbose: run --check and list differing files on failure
run_prettier_verbose() {
	log "${YELLOW}→ Prettier check${RESET}"
	tmpfile="$(mktemp 2>/dev/null || echo "/tmp/prettier_output.$$")"
	if npx prettier --check . >"$tmpfile" 2>&1; then
		log "${GREEN}✔ Prettier passed${RESET}"
		rm -f "$tmpfile"
	else
		log "${YELLOW}⚠ Prettier check failed — files that differ:${RESET}"
		npx prettier --list-different . || true
		log "${YELLOW}Auto-fixing formatting issues...${RESET}"

		if npx prettier --write . >"$tmpfile" 2>&1; then
			git add . 2>/dev/null || true
			log "${GREEN}✔ Prettier auto-fixed files and staged changes.${RESET}"
			rm -f "$tmpfile"
			add_pass
			return 0
		else
			log "${YELLOW}⚠ Prettier auto-fix encountered issues — continuing with warning${RESET}"
			cat "$tmpfile" >&2
			rm -f "$tmpfile"
			add_warn
			return 0
		fi
	fi
}

# Demo failure mode: set PRE_COMMIT_DEMO=1 to force a failing output for screenshots
if [ "${PRE_COMMIT_DEMO}" = "1" ]; then
	log "${YELLOW}Demo mode enabled: showing a failing check${RESET}"
	log "${RED}✖ Demo check failed — commit aborted${RESET}"
	exit 1
fi

# Run checks (verbose for visibility)
# Quick git whitespace/conflict check
# run_whitespace_check

# Formatting and type checks
run_prettier_verbose

# Type check
run_check_verbose "Type check" "npx tsc --noEmit"

