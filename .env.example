# Notion Blog Integration
# Get these from your Notion integration settings
NOTION_TOKEN=secret_xxx
NOTION_BLOG_DATABASE_ID=your_database_id_here

# ISR webhook revalidation secret (set the same value in your Notion webhook)
REVALIDATE_SECRET=your_revalidation_secret_here

# Optional: Vercel deployment token (used in CI)
# VERCEL_TOKEN=xxx
